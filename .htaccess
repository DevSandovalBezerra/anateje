# ANATEJE - Apache Rewrite Rules (local/prod friendly)

RewriteEngine On
RewriteBase /anateje/

# Serve existing files/directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Optional public alias kept for legacy links
RewriteRule ^matricula\.php$ frontend/public/matricula.php [QSA,L]

# Modular API (v2) entrypoint
RewriteRule ^api/v2(?:/.*)?$ api/v2/index.php [QSA,L]

# Front controller fallback
RewriteRule ^ index.php [QSA,L]
